# Telegram Bot API token — получить у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Секрет для проверки, что вебхук-запросы приходят от Telegram (см. README → Деплой на Yandex Cloud Functions).
# Сгенерируйте случайную строку (буквы/цифры/-/_), одна и та же должна быть и здесь, и в переменных окружения функции.
WEBHOOK_SECRET=
