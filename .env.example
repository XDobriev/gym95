# Telegram Bot API token — получить у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# URL Telegram Mini App (деплой на Vercel). Если задан — бот включает menu-кнопку
# «Дневник» и команду /app. Оставь пустым, если Mini App ещё не задеплоен.
WEBAPP_URL=

# Нужен только для архивного способа деплоя на Yandex Cloud Functions (см. README) — для Render не используется.
WEBHOOK_SECRET=
