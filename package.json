{
  "name": "gym95",
  "version": "1.0.0",
  "description": "Личный Telegram-бот — дневник тренировок",
  "private": true,
  "main": "dist/bot.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:webhook": "esbuild src/webhook.ts --bundle --platform=node --target=node22 --outfile=dist/webhook-bundle.js --minify --sourcemap=inline",
    "start": "node dist/bot.js",
    "dev": "tsx watch src/bot.ts",
    "set-webhook": "tsx scripts/set-webhook.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "node-cron": "^4.6.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
